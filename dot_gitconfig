[alias]
    co = checkout
    br = branch
    st = status
    unstage = reset HEAD --

    stat = status -s

    lol = "log --graph --decorate --pretty=oneline --abbrev-commit --all";
    lop = "log -p";

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true

[merge]
    conflictStyle = zdiff3

[include]
    path = ~/.gitconfig.local

[commit]
	gpgsign = true
[tag]
	gpgSign = true
